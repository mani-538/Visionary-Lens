# Visionary Lens - Production Environment Variables Template

# Gemini AI Key (Get it from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Security
# Generate a strong secret key using: openssl rand -hex 32
SECRET_KEY=visionary_lens_secret_key_change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration (PostgreSQL URL expected for production, e.g., Supabase)
# Local SQLite format: sqlite:///./visionary_lens.db
# Supabase PostgreSQL format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./visionary_lens.db

# Cloudinary Integration for Image Storage
# Find this URL on your Cloudinary dashboard to store images securely
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>
