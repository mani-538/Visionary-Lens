# Visionary Lens - Backend Configuration

# Gemini AI Key (Get it from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Security
SECRET_KEY=visionary_lens_secret_key_change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./visionary_lens.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/dbname

# App Settings
PORT=8000
HOST=0.0.0.0
DEBUG=True
